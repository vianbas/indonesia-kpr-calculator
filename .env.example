# Copy this file to .env.local for local overrides (not tracked by git).
# VITE_* variables are inlined into the JS bundle at build time — never put secrets here.
# Non-prefixed variables (SENTRY_*) are used at build time only and never bundled.

# ── Error tracking ─────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# ── Sentry source map upload (build-time only, never shipped to the browser) ───
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
