name = "kpr-share-api"
main = "src/index.ts"
compatibility_date = "2024-12-18"
preview_urls = false

# Bind the Worker to a custom domain. The zone must be on the same Cloudflare
# account as this Worker; wrangler provisions the DNS record + edge cert on deploy.
[[routes]]
pattern = "api.kpr.vikoabastian.com"
custom_domain = true

[[d1_databases]]
binding = "DB"
database_name = "kpr-shares"
database_id = "REPLACE_WITH_YOUR_D1_DATABASE_ID"

[vars]
# Must match the frontend origin: CORS check + the ${APP_ORIGIN}/s/:id share URL.
CORS_ORIGIN          = "https://kpr.vikoabastian.com"
APP_ORIGIN           = "https://kpr.vikoabastian.com"
MAX_PAYLOAD_BYTES    = "10240"
RATE_LIMIT_PER_MINUTE = "10"
SHARE_EXPIRY_DAYS    = "90"
# IP_HASH_SECRET and TURNSTILE_SECRET must be set as Worker Secrets (wrangler secret put ...)
