# Dependencies — reinstalled inside the builder via npm ci
node_modules

# Previous build output — the builder produces its own
dist

# Version control — not needed in the build context
.git
.gitignore

# Editor / OS noise
.vscode
.idea
.DS_Store
*.suo
*.sw?

# Test output
coverage

# Runtime logs
*.log
npm-debug.log*
yarn-debug.log*

# Local environment overrides — secrets must never be baked into the image
.env
.env.*
*.local
